# Model to load (must match VLLM_MODEL in ResaleAI .env)
VLLM_MODEL=Qwen/Qwen3-4B

# API key for authentication (clients must send this as Bearer token)
VLLM_API_KEY=

# HuggingFace token for gated models (optional)
HF_TOKEN=

# GPU device IDs to expose to vLLM (examples: 0, 1, or 0,1)
VLLM_GPU_DEVICES=0

# For named tunnels only; leave empty for quick tunnels (*.trycloudflare.com)
CLOUDFLARE_TUNNEL_TOKEN=
