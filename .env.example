# Docker image to run.
# RTX 3090 / newest vLLM: vllm/vllm-openai:latest
# Tesla P40 / Pascal legacy: ghcr.io/sasha0552/vllm:latest
VLLM_IMAGE=vllm/vllm-openai:latest

# Model to load
VLLM_MODEL=QuantTrio/Qwen3-VL-30B-A3B-Instruct-AWQ

# API key for authentication (clients must send this as Bearer token)
VLLM_API_KEY=

# HuggingFace token for gated models (optional)
HF_TOKEN=

# GPU device ID to expose to vLLM (0 = RTX 3090, 1 = Tesla P40 on this host)
VLLM_GPU_DEVICES=0

# For named tunnels only; leave empty for quick tunnels (*.trycloudflare.com)
CLOUDFLARE_TUNNEL_TOKEN=
